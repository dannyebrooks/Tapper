{
  "appId": "com.tapflow.app",
  "appName": "TapFlow",
  "webDir": "game",
  "bundledWebRuntime": false,
  "server": {
    "androidScheme": "https",
    "iosScheme": "capacitor"
  },
  "ios": {
    "contentInset": "never",
    "preferredContentMode": "mobile",
    "allowsLinkPreview": false,
    "scrollEnabled": false,
    "splash": {
      "backgroundColor": "#0B0F1C"
    }
  },
  "android": {
    "backgroundColor": "#0B0F1C"
  },
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": true,
      "backgroundColor": "#0B0F1C",
      "androidSplashResourceName": "splash",
      "androidScaleType": "CENTER_CROP",
      "showSpinner": false,
      "splashFullScreen": true,
      "splashImmersive": true
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#0B0F1C"
    }
  }
}
